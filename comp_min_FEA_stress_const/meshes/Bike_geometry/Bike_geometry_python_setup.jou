#!python
cubit.cmd('reset')
cubit.cmd('create vertex 0 0 0')
cubit.cmd('create vertex 0.23 0 0')
cubit.cmd('create vertex 0.23 0.075 0')
cubit.cmd('create vertex 0 0.075 0')
cubit.cmd('create vertex 0.035 0.0375 0')
cubit.cmd('create vertex 0.047 0.0375 0')
cubit.cmd('create curve arc center vertex 5 6 6')
cubit.cmd('create vertex 0.205 0.0375 0')
cubit.cmd('create vertex 0.21214375 0.0375 0')
cubit.cmd('create curve arc center vertex 7 8 8')
cubit.cmd('create curve polyline vertex 1 2 3 4 1')
cubit.cmd('create surface curve 1 2 3 4 5 6')
cubit.cmd('split curve 2 midpoint')
cubit.cmd('surface 1 scheme pave')
cubit.cmd('surface 1 size auto factor 1')
cubit.cmd('mesh surface 1')
cubit.cmd('create displacement on curve 1 dof all fix')
cubit.cmd('create displacement on curve 8 dof all fix')
cubit.cmd('export abaqus "C:/Users/benru/OneDrive/Documents/University/Durham/Course/Research and Development Project/Project/Individual Section/rough_bike_crank_geometry.inp" nodefile "C:/Users/benru/OneDrive/Documents/University/Durham/Course/Research and Development Project/Project/Individual Section/nodes.dat" elementfile "C:/Users/benru/OneDrive/Documents/University/Durham/Course/Research and Development Project/Project/Individual Section/elements.dat" dimension 2 overwrite everything')